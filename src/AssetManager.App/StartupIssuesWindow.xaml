<Window x:Class="AssetManager.App.StartupIssuesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="読み込み時の修復・除外内容"
        Width="920"
        Height="560"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,14">
      <TextBlock Style="{StaticResource HeadingTextStyle}" Text="管理データの修復・除外" />
      <TextBlock Margin="0,5,0,0"
                 Style="{StaticResource BodyTextStyle}"
                 Text="安全に読み込めなかった内容です。詳細はローカルログにも記録されています。" />
    </StackPanel>
    <TabControl Grid.Row="1">
      <TabItem Header="初期化したカラム">
        <DataGrid Margin="8"
                  ItemsSource="{Binding Repairs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Width="180" Header="レコードID" Binding="{Binding RecordId}" />
            <DataGridTextColumn Width="160" Header="カラム" Binding="{Binding FieldId}" />
            <DataGridTextColumn Width="2*" Header="理由" Binding="{Binding Reason}" />
            <DataGridTextColumn Width="2*" Header="元の内容" Binding="{Binding OriginalContent}" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="除外したレコード">
        <DataGrid Margin="8"
                  ItemsSource="{Binding ExcludedRecords}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Width="2*" Header="対象ファイル" Binding="{Binding Path}" />
            <DataGridTextColumn Width="3*" Header="理由" Binding="{Binding Error}" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
    </TabControl>
    <Button Grid.Row="2"
            Margin="0,14,0,0"
            HorizontalAlignment="Right"
            IsCancel="True"
            Content="閉じる" />
  </Grid>
</Window>
