<Window x:Class="AssetManager.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:AssetManager.App.Windows"
        Title="設定"
        Width="680"
        Height="520"
        MinWidth="600"
        MinHeight="460"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Style="{StaticResource HeadingTextStyle}" Text="設定" />

    <Border Grid.Row="1" Margin="0,16,0,14" Style="{StaticResource CardStyle}">
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Text="動作設定" />
        <CheckBox Margin="0,14,0,12"
                  Content="起動時に全レコードのパスを確認する"
                  IsChecked="{Binding CheckPathsOnStartup}" />
        <TextBlock Text="ライセンス最終確認日の警告日数" />
        <DockPanel Margin="0,5,0,12" MaxWidth="220" HorizontalAlignment="Left">
          <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" VerticalAlignment="Center" Text="日" />
          <TextBox Text="{Binding LicenseWarningDays, UpdateSourceTrigger=PropertyChanged}"
                   HorizontalContentAlignment="Right"
                   windows:NumericInputBehavior.IsEnabled="True"
                   windows:NumericInputBehavior.IsInteger="True" />
        </DockPanel>
        <Button HorizontalAlignment="Left" Command="{Binding SaveSettingsCommand}" Content="動作設定を保存" />
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Text="データ保存先" />
        <TextBlock Margin="0,10,0,3" Style="{StaticResource BodyTextStyle}" Text="現在の保存先" />
        <TextBlock Text="{Binding CurrentDataRoot}" TextWrapping="Wrap" />
        <TextBlock Margin="0,14,0,3" Style="{StaticResource BodyTextStyle}" Text="変更先（空のフォルダー）" />
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Margin="8,0,0,0"
                  Style="{StaticResource SecondaryButtonStyle}"
                  Command="{Binding BrowseDestinationCommand}"
                  Content="参照" />
          <TextBox Text="{Binding DestinationRoot, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>
        <TextBlock Margin="0,10,0,12"
                   Style="{StaticResource StatusTextStyle}"
                   Text="管理JSONだけをコピーします。登録素材の実ファイルは移動・削除しません。" />
        <Button HorizontalAlignment="Left"
                Command="{Binding ChangeDataRootCommand}"
                Content="コピー・検証して保存先を変更" />
      </StackPanel>
    </Border>

    <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource StatusTextStyle}" Text="{Binding StatusMessage}" />
  </Grid>
</Window>
