<Window x:Class="AssetManager.App.ManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="カラム・マスタ管理"
        Width="820"
        Height="620"
        MinWidth="700"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,14">
      <TextBlock Style="{StaticResource HeadingTextStyle}" Text="管理" />
      <TextBlock Margin="0,4,0,0"
                 Style="{StaticResource BodyTextStyle}"
                 Text="一覧で項目を選ぶと編集できます。レコードなどで使用中のマスタ項目は削除できません。" />
    </StackPanel>
    <TabControl Grid.Row="1">
      <TabItem Header="カスタムカラム">
        <Grid Margin="12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <ListBox ItemsSource="{Binding CustomFields}"
                   SelectedItem="{Binding SelectedField}"
                   DisplayMemberPath="Label" />
          <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="カラム名" />
            <TextBox Margin="0,4,0,10" Text="{Binding FieldName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="型" />
            <ComboBox Margin="0,4,0,10" ItemsSource="{Binding CustomFieldTypes}" SelectedItem="{Binding FieldType}" />
            <TextBlock Text="選択肢（単一／複数選択のみ・カンマ区切り）" />
            <TextBox Margin="0,4,0,10" Text="{Binding FieldOptions}" />
            <CheckBox Margin="0,2" Content="中央一覧に表示" IsChecked="{Binding FieldMainVisible}" />
            <CheckBox Margin="0,2,0,12" Content="右詳細に表示" IsChecked="{Binding FieldDetailVisible}" />
            <StackPanel Orientation="Horizontal">
              <Button Command="{Binding SaveFieldCommand}" Content="保存" />
              <Button Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewFieldCommand}" Content="新規入力" />
              <Button Margin="6,0,0,0" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteFieldCommand}" Content="削除" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="種類">
        <Grid Margin="12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <ListBox ItemsSource="{Binding AssetTypes}" SelectedItem="{Binding SelectedAssetType}" DisplayMemberPath="Name" />
          <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="種類名" />
            <TextBox Margin="0,4,0,10" Text="{Binding AssetTypeName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="自動判定する拡張子（カンマ区切り、例: .png, .jpg）" />
            <TextBox Margin="0,4,0,12" Text="{Binding AssetTypeExtensions}" />
            <StackPanel Orientation="Horizontal">
              <Button Command="{Binding SaveAssetTypeCommand}" Content="保存" />
              <Button Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewAssetTypeCommand}" Content="新規入力" />
              <Button Margin="6,0,0,0" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteAssetTypeCommand}" Content="削除" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="購入／入手元">
        <Grid Margin="12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <ListBox ItemsSource="{Binding AcquisitionSources}"
                   SelectedItem="{Binding SelectedAcquisitionSource}"
                   DisplayMemberPath="Label" />
          <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="購入／入手元名" />
            <TextBox Margin="0,4,0,12"
                     Text="{Binding AcquisitionSourceName, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Orientation="Horizontal">
              <Button Command="{Binding SaveAcquisitionSourceCommand}" Content="保存" />
              <Button Margin="6,0,0,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Command="{Binding NewAcquisitionSourceCommand}"
                      Content="新規入力" />
              <Button Margin="6,0,0,0"
                      Style="{StaticResource DangerButtonStyle}"
                      Command="{Binding DeleteAcquisitionSourceCommand}"
                      Content="削除" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="定型ライセンス">
        <Grid Margin="12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <ListBox ItemsSource="{Binding LicensePresets}"
                   SelectedItem="{Binding SelectedLicensePreset}"
                   DisplayMemberPath="Name" />
          <ScrollViewer Grid.Column="1" Margin="18,0,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <TextBlock Text="定型ライセンス名" />
              <TextBox Margin="0,4,0,12"
                       Text="{Binding LicensePresetName, UpdateSourceTrigger=PropertyChanged}" />
              <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="ライセンス条件" />
              <ItemsControl Margin="0,0,0,12" ItemsSource="{Binding LicensePresetConditions}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Margin="0,3,8,3"
                              Content="{Binding Label}"
                              IsChecked="{Binding IsChecked}"
                              ToolTip="{Binding ToolTip}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SaveLicensePresetCommand}" Content="保存" />
                <Button Margin="6,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding NewLicensePresetCommand}"
                        Content="新規入力" />
                <Button Margin="6,0,0,0"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding DeleteLicensePresetCommand}"
                        Content="削除" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <TabItem Header="タグ分類">
        <Grid Margin="12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name" />
          <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="分類名" />
            <TextBox Margin="0,4,0,12" Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Orientation="Horizontal">
              <Button Command="{Binding SaveCategoryCommand}" Content="保存" />
              <Button Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewCategoryCommand}" Content="新規入力" />
              <Button Margin="6,0,0,0" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteCategoryCommand}" Content="削除" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="タグ">
        <Grid Margin="12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <ListBox ItemsSource="{Binding Tags}" SelectedItem="{Binding SelectedTag}" DisplayMemberPath="Name" />
          <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="タグ名" />
            <TextBox Margin="0,4,0,10" Text="{Binding TagName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="色（#RRGGBB）" />
            <TextBox Margin="0,4,0,10" Text="{Binding TagColor}" />
            <TextBlock Text="分類（任意）" />
            <ComboBox Margin="0,4,0,12"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding TagCategory}"
                      DisplayMemberPath="Name" />
            <StackPanel Orientation="Horizontal">
              <Button Command="{Binding SaveTagCommand}" Content="保存" />
              <Button Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewTagCommand}" Content="新規入力" />
              <Button Margin="6,0,0,0" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteTagCommand}" Content="削除" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
