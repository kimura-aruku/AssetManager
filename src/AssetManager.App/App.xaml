<Application x:Class="AssetManager.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <ResourceDictionary>
      <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Themes/Default/Colors.xaml" />
        <ResourceDictionary Source="Themes/Default/Metrics.xaml" />
        <ResourceDictionary Source="Themes/Default/Controls.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
