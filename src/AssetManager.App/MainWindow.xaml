<Window x:Class="AssetManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AssetManager"
        Width="880"
        Height="520"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="{StaticResource PageMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Style="{StaticResource TitleTextStyle}"
                 Text="AssetManager" />
      <TextBlock Margin="0,6,0,0"
                 Style="{StaticResource BodyTextStyle}"
                 Text="制作素材のパスと利用条件を、実ファイルから分離して管理します。" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,24,0,24"
            Style="{StaticResource CardStyle}">
      <StackPanel MaxWidth="520"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <TextBlock HorizontalAlignment="Center"
                   Style="{StaticResource HeadingTextStyle}"
                   Text="{Binding StartupSummary}" />
        <TextBlock Margin="0,12,0,20"
                   HorizontalAlignment="Center"
                   Style="{StaticResource BodyTextStyle}"
                   Text="{Binding DataRoot, StringFormat=データ保存先: {0}}"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />
        <TextBlock Margin="0,0,0,20"
                   HorizontalAlignment="Center"
                   Style="{StaticResource BodyTextStyle}"
                   Text="{Binding RecordCount, StringFormat=登録素材: {0} 件}" />
        <StackPanel HorizontalAlignment="Center"
                    Orientation="Horizontal">
          <Button Command="{Binding CheckAllPathsCommand}"
                  Content="全レコードのパスを確認" />
          <Button Margin="8,0,0,0"
                  Command="{Binding CancelPathCheckCommand}"
                  Content="キャンセル" />
        </StackPanel>
      </StackPanel>
    </Border>

    <TextBlock Grid.Row="2"
               Style="{StaticResource StatusTextStyle}"
               Text="{Binding StatusMessage}" />
  </Grid>
</Window>
