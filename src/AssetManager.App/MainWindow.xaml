<Window x:Class="AssetManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AssetManager"
        Width="880"
        Height="520"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="{StaticResource PageMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Style="{StaticResource TitleTextStyle}"
                 Text="AssetManager" />
      <TextBlock Margin="0,6,0,0"
                 Style="{StaticResource BodyTextStyle}"
                 Text="制作素材のパスと利用条件を、実ファイルから分離して管理します。" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,24,0,24"
            Style="{StaticResource CardStyle}">
      <StackPanel MaxWidth="520"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <TextBlock HorizontalAlignment="Center"
                   Style="{StaticResource HeadingTextStyle}"
                   Text="プロジェクト基盤の準備が完了しました" />
        <TextBlock Margin="0,12,0,20"
                   HorizontalAlignment="Center"
                   Style="{StaticResource BodyTextStyle}"
                   Text="次の実装で、素材レコードと動的カラムのドメインモデルを追加します。"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />
        <Button HorizontalAlignment="Center"
                Command="{Binding ConfirmEnvironmentCommand}"
                Content="準備状態を確認" />
      </StackPanel>
    </Border>

    <TextBlock Grid.Row="2"
               Style="{StaticResource StatusTextStyle}"
               Text="{Binding StatusMessage}" />
  </Grid>
</Window>
