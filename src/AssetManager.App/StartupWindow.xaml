<Window x:Class="AssetManager.App.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AssetManager を起動しています"
        Width="480"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Style="{StaticResource HeadingTextStyle}"
               Text="AssetManager" />

    <TextBlock Grid.Row="1"
               VerticalAlignment="Center"
               Style="{StaticResource BodyTextStyle}"
               Text="{Binding Message}"
               TextWrapping="Wrap" />

    <ProgressBar Grid.Row="2"
                 Height="8"
                 Maximum="{Binding TotalSteps, Mode=OneWay}"
                 Value="{Binding CompletedSteps, Mode=OneWay}" />
  </Grid>
</Window>
